{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "lib": [
            "esnext"
        ],
        "target": "ESNext",
        "moduleResolution": "node",
        "module": "CommonJS",
        "strict": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}