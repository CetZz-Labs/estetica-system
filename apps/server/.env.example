# Puerto en el que escucha el servidor Express (opcional, default interno según index.ts)
PORT=

# Cadena de conexión a MongoDB Atlas (o instancia local)
DATABASE_URL=

# URL del frontend autorizada por CORS (ej. http://localhost:5173)
FRONTEND_URL=

# Credenciales de Clerk (autenticación)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# String secreto de 32+ caracteres usado para cifrar credenciales SMTP por tenant (AES-256-GCM).
# Generar con: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=
